{
  "name": "Folio Ebook Reader",
  "short_name": "Folio",
  "description": "A premium browser-based ebook reader supporting EPUB, PDF, DOCX, and more.",
  "start_url": "/folio-reader/",
  "scope": "/folio-reader/",
  "display": "standalone",
  "background_color": "#16130f",
  "theme_color": "#d4935a",
  "orientation": "any",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/folio-reader/",
      "accept": {
        "application/epub+zip":                                                    [".epub"],
        "application/pdf":                                                         [".pdf"],
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": [".docx"],
        "application/msword":                                                      [".doc"],
        "text/plain":                                                              [".txt"],
        "text/markdown":                                                           [".md", ".markdown"],
        "text/html":                                                               [".html", ".htm"],
        "text/rtf":                                                                [".rtf"],
        "application/rtf":                                                         [".rtf"]
      },
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "categories": ["books", "education", "productivity"]
}
